# Required: Fathom webhook signature verification
FATHOM_WEBHOOK_SECRET=whsec_REPLACE_ME

# Required: LLM matching
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# Required: folder containing the existing notes docs to scan
GOOGLE_DRIVE_TARGET_FOLDER_ID=REPLACE_ME

# Optional: fixed write target doc (not used by V1 matching flow)
GOOGLE_DOC_ID=REPLACE_ME

# Required: one-line service account JSON for Drive/Docs API
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

# Optional
LOG_LEVEL=INFO
